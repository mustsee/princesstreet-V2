---
import { Icon } from "astro-icon";

import i18next from "i18next";

import en from "~/../public/locales/en/translation.json";
import fr from "~/../public/locales/fr/translation.json";
import es from "~/../public/locales/es/translation.json";

const contents = {
  en,
  fr,
  es,
};

const currentLanguage = i18next.language;
const content = contents[currentLanguage];

/* const faq = content.faq; */

const faq = [
 "faq": [
  {
    "question": "Do you have luggage storage if I arrive before check-in time?",
    "answer": "Yes. Free luggage storage is available from 8am, both before check-in and after check-out for the full day. Guests do not need to wait until their room is ready to drop off bags."
  },
  {
    "question": "What time is check-in and check-out?",
    "answer": "Check-in opens at 3pm and check-out is by 10am. Free luggage storage is available from 8am if you arrive before your room is ready, and for the full day after check-out."
  },
  {
    "question": "Where is Princes Street Hostel located?",
    "answer": "Princes Street Hostel and Haystack Hostel are located on the edge of Edinburgh's New Town, a short walk from Waverley Train Station and Edinburgh Bus Station, with direct tram and Airlink 100 bus connections from Edinburgh Airport. The flat New Town location avoids the steep climbs common near Old Town accommodation."
  },
  {
    "question": "How close is the hostel to Edinburgh Castle and the Royal Mile?",
    "answer": "The hostel is around a 10–15 minute walk from both Edinburgh Castle and the Royal Mile. Being based in the New Town means you can stroll down to the Old Town's main attractions without the uphill return climb that catches out guests staying closer to the castle."
  },
  {
    "question": "How far is Waverley Train Station from the hostel?",
    "answer": "Waverley Station is approximately a 5 minute walk from the hostel, making it one of the most conveniently located hostels in Edinburgh for rail travellers. There is no need for a taxi or bus connection from the station."
  },
  {
    "question": "How far is Edinburgh Bus Station from the hostel?",
    "answer": "Edinburgh Bus Station (St Andrew Square) is within a 5 minute walk, making the hostel equally convenient for coach arrivals from other UK cities or Scottish towns."
  },
  {
    "question": "How do I get from Edinburgh Airport to the hostel?",
    "answer": "The two best options are the Airlink 100 bus and the Edinburgh Tram. The Airlink 100 runs 24 hours, departing from Waverley Bridge every 10 minutes (04:00–00:10) and every 30 minutes overnight. The tram departs from St Andrew Square every 7 minutes between 7am–7pm and every 15 minutes at other times, with no service between midnight and 6am. Both stops are a short walk from the hostel. Journey time is approximately 30 minutes."
  },
  {
    "question": "Is Edinburgh easy to get around without a car?",
    "answer": "Yes. Edinburgh's city centre is compact and very walkable. Most major attractions — the Royal Mile, Holyrood Palace, Calton Hill, Princes Street Gardens, and the National Museum — are reachable on foot from the hostel. For destinations further afield, Lothian Buses operate frequent services across the city, and the tram line connects the city centre to Murrayfield, Edinburgh Park, and the Airport."
  },
  {
    "question": "Is the hostel in a safe area of Edinburgh?",
    "answer": "Yes. The hostel is situated in Edinburgh's New Town, a well-lit, busy, and well-connected central neighbourhood. It is considered one of the safest and most accessible parts of the city for visitors."
  },
  {
    "question": "Where can I park near the hostel?",
    "answer": "The hostel is in the city centre where parking is limited and public transport is strongly recommended. If driving, the RingGo app can be used for paid parking on Waterloo Place, St Andrews Square, or George Street. On-street parking is free between 6:30pm and 8:30am."
  },
  {
    "question": "Is reception open 24 hours?",
    "answer": "Reception is staffed until midnight on weekdays and until 2am on weekends. A member of staff remains on site around the clock for emergencies. Guests expecting a late arrival should contact the hostel in advance — self check-in instructions can be arranged, but we do need to know ahead of time."
  },
  {
    "question": "What ID do I need to check in?",
    "answer": "A valid government-issued photo ID is required at check-in. Accepted documents include a passport, national identity card, or driving licence."
  },
  {
    "question": "What dorm sizes are available, and do you have private rooms?",
    "answer": "Princes Street Hostel offers a range of room types, from 12-bed dormitories through to private double rooms. Whether you're looking for a social dorm experience or more privacy, there's an option to suit."
  },
  {
    "question": "Can I reserve a bottom bunk?",
    "answer": "Bottom bunks cannot be reserved in advance. Bed allocation is first come, first served. Arriving promptly at check-in time gives the best chance of securing a preferred bunk."
  },
  {
    "question": "Is there a minimum age requirement?",
    "answer": "Guests must be 18 or over to stay in a shared dormitory room. Guests under 18 are welcome in private rooms only and must be accompanied by an adult."
  },
  {
    "question": "Are there power sockets near the beds?",
    "answer": "Yes. Each bed has access to both a USB Type-A charging port and a standard power socket, so you can charge your devices without needing an adaptor or extension lead."
  },
  {
    "question": "Do you have WiFi?",
    "answer": "Yes. WiFi is available throughout the hostel. The password is provided at check-in."
  },
  {
    "question": "Are there lockers in the dorm rooms?",
    "answer": "Yes. Each shared room has lockers measuring approximately 80cm × 30cm × 40cm, suitable for a large backpack or carry-on suitcase. Padlocks are available to purchase at reception for £4. Larger items can sometimes be stored separately on request."
  },
  {
    "question": "Are linen and towels provided?",
    "answer": "Linen, duvets, and pillows are provided in all rooms. Towels are not included in dorm bookings but can be hired at reception for £3 per person. Towels are included in double room bookings."
  },
  {
    "question": "Are the bathrooms gender-specific?",
    "answer": "This varies by floor. Some floors have gender-specific bathrooms; others have single-stall toilets. Shower stalls are generally mixed-use but fully enclosed and private."
  },
  {
    "question": "Is there a lift?",
    "answer": "Unfortunately not. The hostel is located at the top of a traditional Edinburgh tenement building with no lift. Guests with mobility requirements should be aware of this before booking."
  },
  {
    "question": "Do you serve breakfast?",
    "answer": "Breakfast is available at SNAX Café, located directly beneath the hostel. Vouchers can be purchased from reception for £5, covering a barista-style coffee or hot drink plus a filled roll. A full Scottish breakfast is also available at the same price."
  },
  {
    "question": "Is there a self-catering kitchen?",
    "answer": "Yes. A fully equipped kitchen with utensils and crockery is available to all guests, open from 8am to midnight. Guests are asked to keep it clean and tidy."
  },
  {
    "question": "Do you have a laundry service?",
    "answer": "There is no in-house laundry service, but staff can direct guests to nearby laundrettes."
  },
  {
    "question": "Is there bicycle storage?",
    "answer": "Yes, secure bicycle storage is available. Please note that the hostel is at the top of a building with several flights of stairs."
  },
  {
    "question": "Are groups welcome?",
    "answer": "Yes, groups are welcome. For group bookings please get in touch directly so we can discuss availability and arrangements."
  },
  {
    "question": "Are pets allowed?",
    "answer": "No, pets are not permitted at the hostel."
  },
  {
    "question": "When is payment taken?",
    "answer": "For flexible bookings, payment is taken when the free cancellation period ends. Non-refundable bookings are charged immediately upon reservation. Unpaid reservations are not guaranteed — if a payment fails, guests will be contacted to update their card details."
  },
  {
    "question": "What is the cancellation policy?",
    "answer": "Cancellation terms vary depending on your booking type and the platform you booked through. Please refer to the terms and conditions in your booking confirmation for the specific policy that applies to your reservation."
  },
  {
    "question": "Can I extend my stay?",
    "answer": "Yes, extensions are possible subject to availability. Please note that the hostel does not accommodate long-term or live-in stays, and consecutive stays are limited to a maximum of 7 nights."
  },
  {
    "question": "My question isn't answered here — how can I contact you?",
    "answer": "Don't hesitate to reach out to us directly via WhatsApp and we'll be happy to help."
  }
];

// Check if content is present in object
// Object might be empty
const faqFiltered = faq.filter((item) => {
  if (item.hasOwnProperty("question") && item.hasOwnProperty("answer"))
    return item;
});

const faqFilteredLength = faqFiltered.length;
const firstColLength = Math.ceil(faqFilteredLength / 2);

const itemsFirstCol = faqFiltered.slice(0, firstColLength);
const itemsSecondCol = faqFiltered.slice(firstColLength);

const items = [itemsFirstCol, itemsSecondCol];
---

<div class="px-4 py-16 mx-auto max-w-6xl lg:py-20">
  <div class="max-w-xl sm:mx-auto lg:max-w-2xl">
    <div class="max-w-xl mb-10 md:mx-auto sm:text-center lg:max-w-2xl md:mb-12">
      <h2
        class="max-w-lg mb-4 text-3xl font-bold leading-none tracking-tight sm:text-4xl md:mx-auto font-heading"
      >
        Frequently Asked Questions
      </h2>
    </div>
  </div>
  <div class="max-w-screen-xl sm:mx-auto">
    <div class="grid grid-cols-1 gap-x-8 gap-y-8 lg:gap-x-16 md:grid-cols-2">
      {
        items.map((subitems) => (
          <div class="space-y-8">
            {subitems.map(({ question, answer }) => (
              <div>
                <p class="mb-4 text-xl font-bold">
                  <Icon
                    name="tabler:arrow-down-right"
                    class="w-7 h-7 text-primary-500 inline-block"
                  />
                  {question && question}
                </p>
                {answer &&
                  answer
                    .split("\n\n")
                    .map((paragraph) => (
                      <p
                        class="text-gray-700 dark:text-gray-400 mb-2"
                        set:html={paragraph}
                      />
                    ))}
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</div>
